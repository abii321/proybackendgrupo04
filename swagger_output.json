      },
      "delete": {
        "tags": [
          "Admin"
        ],
        "summary": "Eliminar una tutoría",
        "description": "Elimina una tutoría por su ID. Falla si tiene calificaciones asociadas.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID de la tutoría a eliminar."
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Tutoría eliminada correctamente.",
            "schema": {
              "$ref": "#/definitions/SuccessResponse"
            }
          },
          "400": {
            "description": "No se puede eliminar: tiene registros asociados."
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Error al eliminar tutoría."
          }
        },
