    "/users/{id}": {
      "put": {
        "tags": [
          "Admin"
        ],
        "summary": "Actualizar un usuario",
        "description": "Actualiza los datos de un usuario desde el panel de administración.",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID del usuario a actualizar."
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Datos del usuario a actualizar.",
            "required": true,
            "schema": {
              "$ref": "#/definitions/AdminUpdateUsuario"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Usuario actualizado correctamente.",
            "schema": {
              "$ref": "#/definitions/SuccessResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Usuario no encontrado."
          },
          "500": {
            "description": "Error al actualizar el usuario."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Admin"
        ],
        "summary": "Eliminar un usuario",
        "description": "Elimina un usuario por su ID. Falla si tiene tutorías o solicitudes asociadas.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID del usuario a eliminar."
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
