{
  "swagger": "2.0",
  "info": {
    "title": "TutorMatch API",
    "description": "Documentación de la API de TutorMatch — Grupo 04",
    "version": "1.0.0"
  },
  "host": "localhost:3000",
  "basePath": "/api",
  "tags": [
    {
      "name": "Admin",
      "description": "Operaciones de administración (usuarios, tutorías, categorías y métricas)."
    },
    {
      "name": "Solicitudes",
      "description": "Operaciones relacionadas con las solicitudes de ayuda."
    },
    {
      "name": "Respuestas",
      "description": "Operaciones relacionadas con las respuestas a las solicitudes."
    }
  ],
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "bearerAuth": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "JWT token. Formato: Bearer {token}"
    }
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Solicitudes"
        ],
        "summary": "Listar todas las solicitudes",
        "description": "Retorna el listado completo de solicitudes de ayuda.",
        "responses": {
          "200": {
            "description": "Listado de solicitudes obtenido correctamente.",
            "schema": {
              "$ref": "#/definitions/SolicitudAyudaResponse"
            }
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      },
      "post": {
        "tags": [
          "Respuestas"
        ],
        "summary": "Crear una respuesta",
        "description": "Crea una nueva respuesta para una solicitud abierta. Requiere autenticación.",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Datos de la respuesta a crear.",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RespuestaAyuda"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Respuesta creada correctamente.",
            "schema": {
              "$ref": "#/definitions/RespuestaAyudaResponse"
            }
          },
          "400": {
            "description": "La solicitud ya no acepta respuestas."
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "La solicitud no existe."
          },
          "500": {
            "description": "Error al crear respuesta."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/{id}": {
      "get": {
        "tags": [
          "Solicitudes"
        ],
        "summary": "Obtener una solicitud por ID",
        "description": "Retorna una solicitud de ayuda específica junto con sus respuestas.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID de la solicitud."
          }
        ],
        "responses": {
          "200": {
            "description": "Solicitud encontrada.",
            "schema": {
              "$ref": "#/definitions/SolicitudAyudaResponse"
            }
          },
          "404": {
            "description": "Solicitud no encontrada."
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      },
      "put": {
        "tags": [
          "Respuestas"
        ],
        "summary": "Actualizar una respuesta",
        "description": "Actualiza el contenido de una respuesta existente. Requiere autenticación.",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID de la respuesta a actualizar."
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "description": "Datos actualizados de la respuesta.",
            "required": true,
            "schema": {
              "$ref": "#/definitions/RespuestaAyuda"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Respuesta actualizada correctamente.",
            "schema": {
              "$ref": "#/definitions/SuccessResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Error al actualizar respuesta."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Respuestas"
        ],
        "summary": "Eliminar una respuesta",
        "description": "Elimina una respuesta por su ID. Requiere autenticación.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID de la respuesta a eliminar."
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Respuesta eliminada correctamente.",
            "schema": {
              "$ref": "#/definitions/SuccessResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Error al eliminar respuesta."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/{id}/cerrar": {
      "put": {
        "tags": [
          "Solicitudes"
        ],
        "summary": "Cerrar una solicitud",
        "description": "Cambia el estado de una solicitud a CERRADA. Requiere autenticación.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID de la solicitud a cerrar."
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Solicitud cerrada correctamente.",
            "schema": {
              "$ref": "#/definitions/SuccessResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "500": {
            "description": "Error al cerrar solicitud."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/solicitud/{solicitudId}": {
      "get": {
        "tags": [
          "Respuestas"
        ],
        "summary": "Listar respuestas por solicitud",
        "description": "Retorna todas las respuestas asociadas a una solicitud de ayuda específica.",
        "parameters": [
          {
            "name": "solicitudId",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID de la solicitud."
          }
        ],
        "responses": {
          "200": {
            "description": "Respuestas obtenidas correctamente.",
            "schema": {
              "$ref": "#/definitions/RespuestaAyudaResponse"
            }
          },
          "500": {
            "description": "Error interno del servidor."
          }
        }
      }
    },
    "/{id}/aceptar": {
      "put": {
        "tags": [
          "Respuestas"
        ],
        "summary": "Aceptar una respuesta",
        "description": "Marca una respuesta como ACEPTADA y cierra la solicitud como RESUELTA. Requiere autenticación.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID de la respuesta a aceptar."
          },
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Respuesta aceptada.",
            "schema": {
              "$ref": "#/definitions/SuccessResponse"
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Respuesta no encontrada."
          },
          "500": {
            "description": "Error al aceptar la respuesta."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/summary": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Resumen general del sistema",
        "description": "Retorna métricas generales: total de usuarios, tutorías, solicitudes, categorías y calificación promedio.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Resumen obtenido correctamente.",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "number",
                  "example": 1
                },
                "msg": {
                  "type": "string",
                  "example": "success"
                },
                "data": {
                  "type": "object",
                  "properties": {
                    "totalUsers": {
                      "type": "number",
                      "example": 50
                    },
                    "totalTutorials": {
                      "type": "number",
                      "example": 120
                    },
                    "totalHelpRequests": {
                      "type": "number",
                      "example": 75
                    },
                    "totalCategories": {
                      "type": "number",
                      "example": 10
                    },
                    "avgRating": {
                      "type": "string",
                      "example": "4.3"
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Error al obtener resumen."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/users-by-role": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Usuarios agrupados por rol y estado",
        "description": "Retorna el conteo de usuarios agrupado por rol (alumno, profesor, admin) y estado (activo, inactivo). Útil para gráficos de barra apilada.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Datos obtenidos correctamente.",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "number",
                  "example": 1
                },
                "msg": {
                  "type": "string",
                  "example": "success"
                },
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "rol": {
                        "type": "string",
                        "example": "alumno"
                      },
                      "estado": {
                        "type": "string",
                        "example": "activo"
                      },
                      "count": {
                        "type": "number",
                        "example": 30
                      }
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Error al obtener usuarios por rol."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/requests-by-state": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Solicitudes agrupadas por estado",
        "description": "Retorna el conteo de solicitudes de ayuda agrupadas por estado (ABIERTA, RESUELTA, CERRADA). Útil para gráficos de torta.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Datos obtenidos correctamente.",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "number",
                  "example": 1
                },
                "msg": {
                  "type": "string",
                  "example": "success"
                },
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "estado": {
                        "type": "string",
                        "example": "ABIERTA"
                      },
                      "count": {
                        "type": "number",
                        "example": 40
                      }
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Error al obtener solicitudes por estado."
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/tutorials-by-state": {
      "get": {
        "tags": [
          "Admin"
        ],
        "summary": "Tutorías agrupadas por estado",
        "description": "Retorna el conteo de tutorías agrupadas por estado. Útil para gráficos de torta.",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Datos obtenidos correctamente.",
            "schema": {
              "type": "object",
              "properties": {
                "status": {
                  "type": "number",
                  "example": 1
                },
                "msg": {
                  "type": "string",
                  "example": "success"
                },
                "data": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "estado": {
                        "type": "string",
                        "example": "CONFIRMADA"
                      },
                      "count": {
                        "type": "number",
                        "example": 55
                      }
                    }
                  }
                }
              },
              "xml": {
                "name": "main"
              }
            }
          },
          "401": {
            "description": "Unauthorized"
